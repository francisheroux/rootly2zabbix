# Rootly webhook secret (from Rootly > Workflows > Your Workflow > HTTP Client Action > Secret)
ROOTLY_WEBHOOK_SECRET=your_rootly_webhook_secret_here

# Zabbix API URL
ZABBIX_URL=https://your-zabbix-server/api_jsonrpc.php

# Zabbix API authentication token (Zabbix 5.4+)
ZABBIX_TOKEN=your_zabbix_api_token_here

# How many days to suppress a Zabbix event when resolved from Rootly and closing fails.
# Suppression prevents alert noise when a trigger's conditions are still active at resolution time.
ZABBIX_SUPPRESS_DURATION_DAYS=3

# When resolving from Rootly fails to close a Zabbix event, suppress the event to prevent alert noise.
# Set to false to skip suppression and leave the event as acknowledged instead.
ZABBIX_SUPPRESS_ON_CLOSE_FAILURE=true